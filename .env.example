# ========== LLM API 配置 ==========
# 支持 OpenAI 兼容接口（DeepSeek / Moonshot / 智谱等）
LLM_API_KEY=sk-your-key-here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ========== 服务端口 ==========
PORT=8765
HOST=127.0.0.1

# ========== API 认证（必填，用于用户登录/注册的 HMAC 签名） ==========
# 生成随机密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=change-me-to-a-random-secret

# ========== 数据持久化路径（Docker 部署时用环境变量覆盖） ==========
# SQLITE_PATH=./interview_engine.db
# CHROMA_PERSIST_DIR=./chroma_db
# BM25_INDEX_PATH=./bm25_index.json
